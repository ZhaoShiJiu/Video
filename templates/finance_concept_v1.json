{
  "id": "finance_concept_v1",
  "name": "财经知识认知颠覆型",
  "description": "通过认知冲突引入财经概念，适合短视频知识科普",
  "duration": 60,
  "language": "zh",
  "steps": [
    {
      "key": "hook",
      "duration": "0-5秒",
      "goal": "制造认知冲突",
      "rules": [
        "不要直接解释概念",
        "使用反常识观点",
        "让观众产生好奇"
      ]
    },
    {
      "key": "scenario",
      "duration": "5-15秒",
      "goal": "用生活场景引出问题",
      "rules": [
        "必须选择普通人熟悉的场景",
        "尽量使用金钱、时间、工作、消费等案例"
      ]
    },
    {
      "key": "explanation",
      "duration": "15-35秒",
      "goal": "解释财经概念",
      "rules": [
        "禁止直接复制教材定义",
        "必须结合上面的案例进行解释"
      ]
    },
    {
      "key": "insight",
      "duration": "35-50秒",
      "goal": "提升认知",
      "rules": [
        "说明这个概念对普通人的意义",
        "指出大多数人的认知误区"
      ]
    },
    {
      "key": "ending",
      "duration": "50-60秒",
      "goal": "形成传播性金句",
      "rules": [
        "使用对比句式",
        "让观众产生思考"
      ]
    }
  ]
}
